# VOLANS environment variables.
#
# Copy this file to `.env.local` and fill in the values you want to enable.
# All NEXT_PUBLIC_* vars are shipped to the browser — never put private
# secrets behind those names.

# ---------- Gemini API (server-side only) ----------
# Used by src/app/api/ai/chat/route.ts and OCR flows. Keep server-side.
GEMINI_API_KEY=

# ---------- Firebase Auth + Firestore (optional) ----------
# Leave blank to stay in "local only" mode. When all four are present, VOLANS
# shows the sign-in UI in the header and mirrors saves to Firestore under
# users/{uid}/volansProjects/{id}. See firestore.rules for security.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------- Parcel shape API (optional) ----------
# If not set, the PMTiles (農研機構) fallback is used for 筆界 lookups.
PARCEL_SHAPE_API_URL=
PARCEL_SHAPE_API_KEY=

# ---------- Mapbox (optional) ----------
NEXT_PUBLIC_MAPBOX_TOKEN=
